{
  "name": "3dgs-viewer-spark-test",
  "private": true,
  "scripts": {
    "build": "esbuild viewer.js --bundle --alias:three=./vendor/three/three.module.js --format=iife --platform=browser --target=es2020 --outfile=viewer.bundle.js",
    "test": "node --test tests/*.test.mjs",
    "check": "npm run test && npm run build && node --check viewer.js && htmlhint index.html",
    "dev": "http-server . -p 4173 -c-1 --cors",
    "open": "powershell -ExecutionPolicy Bypass -File .\\tools\\open_viewer.ps1 -Browser Auto",
    "open:chrome": "powershell -ExecutionPolicy Bypass -File .\\tools\\open_viewer.ps1 -Browser Chrome",
    "open:edge": "powershell -ExecutionPolicy Bypass -File .\\tools\\open_viewer.ps1 -Browser Edge"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "htmlhint": "^1.7.1",
    "http-server": "^14.1.1",
    "playwright-core": "^1.59.1"
  }
}
